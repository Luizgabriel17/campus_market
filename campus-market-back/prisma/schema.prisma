generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  VENDEDOR
  ADMIN
}

enum UserStatus {
  ATIVO
  INATIVO
}

enum ProductStatus {
  ATIVO
  INATIVO
}

enum OrderStatus {
  PENDENTE
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  PIX
  CARD
  CASH
}

enum PaymentStatus {
  PENDENTE
  APROVADO
  RECUSADO
}

model User {
  id Int @id @default(autoincrement())

  name String @db.VarChar(100)

  email String @unique @db.VarChar(150)

  password String? @db.VarChar(255)

  googleId String? @unique

  avatar String?

  role Role @default(CLIENTE)

  status UserStatus @default(ATIVO)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Produtos cadastrados pelo vendedor
  products Product[]

  // Compras realizadas pelo cliente
  purchases Order[] @relation("CustomerOrders")

  // Vendas realizadas pelo vendedor
  sales Order[] @relation("SellerOrders")

  // Avaliações feitas
  reviewsMade Review[] @relation("CustomerReviews")

  // Avaliações recebidas
  reviewsReceived Review[] @relation("SellerReviews")

  // Carrinho
  cart Cart?
}

model Category {
  id Int @id @default(autoincrement())

  name String @unique @db.VarChar(100)

  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id Int @id @default(autoincrement())

  sellerId Int

  categoryId Int

  name String @db.VarChar(100)

  description String?

  imageUrl String?

  price Decimal @db.Decimal(10, 2)

  stock Int

  status ProductStatus @default(ATIVO)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  seller User @relation(fields: [sellerId], references: [id])

  category Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]

  cartItems CartItem[]

  @@index([sellerId])
  @@index([categoryId])
}

model Cart {
  id Int @id @default(autoincrement())

  userId Int @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]
}

model CartItem {
  id Int @id @default(autoincrement())

  cartId Int

  productId Int

  quantity Int

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Order {
  id Int @id @default(autoincrement())

  customerId Int

  sellerId Int

  total Decimal @db.Decimal(10, 2)

  status OrderStatus @default(PENDENTE)

  createdAt DateTime @default(now())

  customer User @relation("CustomerOrders", fields: [customerId], references: [id])

  seller User @relation("SellerOrders", fields: [sellerId], references: [id])

  items OrderItem[]

  payment Payment?

  @@index([customerId])
  @@index([sellerId])
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int

  productId Int

  quantity Int

  unitPrice Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Payment {
  id Int @id @default(autoincrement())

  orderId Int @unique

  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod

  status PaymentStatus @default(PENDENTE)

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Review {
  id Int @id @default(autoincrement())

  customerId Int

  sellerId Int

  rating Int

  comment String? @db.VarChar(300)

  createdAt DateTime @default(now())

  customer User @relation("CustomerReviews", fields: [customerId], references: [id])

  seller User @relation("SellerReviews", fields: [sellerId], references: [id])

  @@unique([customerId, sellerId])
}
