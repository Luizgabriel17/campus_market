generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model avaliacoes {
  id             Int       @id @default(autoincrement())
  cliente_id     Int
  vendedor_id    Int
  nota           Int
  comentario     String?   @db.VarChar(80)
  data_avaliacao DateTime? @default(now()) @db.Timestamp(6)
  cliente        cliente   @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_avaliacao_cliente")
  vendedor       vendedor  @relation(fields: [vendedor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_avaliacao_vendedor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cliente {
  id           Int          @id @default(autoincrement())
  nome         String       @db.VarChar(50)
  email        String       @unique @db.VarChar(150)
  senha        String       @db.VarChar(255)
  data_criacao DateTime?    @default(now()) @db.Timestamp(6)
  status       String?      @default("ATIVO") @db.VarChar(10)
  avaliacoes   avaliacoes[]
  pedidos      pedidos[]
}

model itens_pedido {
  id             Int      @id @default(autoincrement())
  pedido_id      Int
  produto_id     Int
  quantidade     Int
  preco_unitario Decimal  @db.Decimal(10, 2)
  pedidos        pedidos  @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_item_pedido")
  produtos       produtos @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_item_produto")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model pedidos {
  id           Int            @id @default(autoincrement())
  cliente_id   Int
  vendedor_id  Int
  valor_total  Decimal        @db.Decimal(10, 2)
  status       String?        @default("PENDENTE") @db.VarChar(20)
  data_pedido  DateTime?      @default(now()) @db.Timestamp(6)
  itens_pedido itens_pedido[]
  cliente      cliente        @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pedido_cliente")
  vendedor     vendedor       @relation(fields: [vendedor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pedido_vendedor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model produtos {
  id           Int            @id @default(autoincrement())
  vendedor_id  Int
  nome         String         @db.VarChar(100)
  descricao    String?
  preco        Decimal        @db.Decimal(10, 2)
  estoque      Int
  status       String?        @default("ATIVO") @db.VarChar(10)
  data_criacao DateTime?      @default(now()) @db.Timestamp(6)
  itens_pedido itens_pedido[]
  vendedor     vendedor       @relation(fields: [vendedor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_produto_vendedor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vendedor {
  id           Int          @id @default(autoincrement())
  nome         String       @db.VarChar(50)
  email        String       @unique @db.VarChar(150)
  senha        String       @db.VarChar(255)
  data_criacao DateTime?    @default(now()) @db.Timestamp(6)
  status       String?      @default("ATIVO") @db.VarChar(10)
  avaliacoes   avaliacoes[]
  pedidos      pedidos[]
  produtos     produtos[]
}
