<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Pedidos - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:#f1f5f9;
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:230px;
  height:100vh;
  background:#ffffff;
  padding:25px 20px;
  position:fixed;
  border-right:1px solid #e2e8f0;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.logo{
  font-weight:800;
  font-size:1.3rem;
  color:#ff5a1f;
  margin-bottom:30px;
}

.menu a{
  display:block;
  padding:10px;
  border-radius:10px;
  color:#334155;
  text-decoration:none;
  margin-bottom:8px;
  transition:.2s;
}

.menu a:hover{
  background:#f1f5f9;
}

.menu .active{
  background:#ff5a1f;
  color:white;
}

.user{
  font-size:0.9rem;
  color:#475569;
}

.user a{
  display:block;
  margin-top:5px;
  color:#ff5a1f;
  text-decoration:none;
}

/* CONTENT */
.content{
  margin-left:230px;
  padding:40px;
  width:100%;
}

/* TITLE */
.title{
  font-size:2rem;
  font-weight:800;
  margin-bottom:30px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:25px;
}

/* CARD */
.card-pedido{
  background:#fff;
  border-radius:18px;
  padding:22px;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  transition:.25s;
}

.card-pedido:hover{
  transform:translateY(-6px);
}

/* HEADER */
.card-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:12px;
}

/* STATUS */
.status{
  padding:6px 12px;
  border-radius:12px;
  font-size:0.75rem;
  font-weight:600;
}

.status-pendente{background:#fff3cd;color:#856404;}
.status-preparando{background:#cce5ff;color:#004085;}
.status-entregue{background:#d4edda;color:#155724;}

/* TEXT */
.itens{
  font-size:0.95rem;
  color:#475569;
}

.total{
  font-weight:700;
  margin-top:10px;
}

/* BUTTON */
.btn-avaliar{
  margin-top:15px;
  background:#ff5a1f;
  color:white;
  border:none;
  padding:10px;
  border-radius:12px;
  font-size:0.9rem;
  cursor:pointer;
  width:100%;
  transition:.2s;
}

.btn-avaliar:hover{
  transform:translateY(-2px);
}

.btn-disabled{
  background:#cbd5e1 !important;
  cursor:not-allowed;
}

/* MODAL */
.modal-content{
  border-radius:16px;
}

/* ESTRELAS */
.stars{
  display:flex;
  justify-content:center;
  gap:8px;
  font-size:1.8rem;
  cursor:pointer;
}

.stars span{
  color:#ccc;
}

.stars span.active{
  color:#ff5a1f;
}
</style>
</head>

<body>

<%- include('partials/header') %>

<div class="content">

<div class="title">Meus Pedidos</div>

<div class="grid">

<% pedidos.forEach(p => { %>

  <div class="card-pedido">

    <div class="card-header">
      <strong>#Pedido <%= p.id %></strong>

      <span class="status 
        <%= p.status === 'PENDENTE' ? 'status-pendente' : '' %>
        <%= p.status === 'PREPARANDO' ? 'status-preparando' : '' %>
        <%= p.status === 'ENTREGUE' ? 'status-entregue' : '' %>">
        <%= p.status %>
      </span>
    </div>

    <div class="itens"><%= p.itens %></div>
    <div class="total">R$ <%= p.valor_total %></div>

    <% if (p.status === "ENTREGUE") { %>

      <% if (p.avaliado) { %>

        <button class="btn-avaliar btn-disabled" disabled>
          Já avaliado
        </button>

        <small style="display:block; margin-top:5px; color:#64748b;">
          Avaliação já enviada
        </small>

      <% } else { %>

        <button 
          type="button"
          class="btn-avaliar abrir-avaliacao"
          data-id="<%= p.id %>"
          data-vendedor="<%= p.vendedor_id %>">
          Avaliar
        </button>

      <% } %>

    <% } %>

  </div>

<% }) %>

</div>

</div>

<!-- MODAL -->
<div class="modal" id="modalAvaliacao" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <form action="/avaliacoes/avaliar" method="POST">

        <div class="modal-header">
          <h5>Avaliar Pedido</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body text-center">

          <input type="hidden" name="pedido_id" id="pedido_id">
          <input type="hidden" name="vendedor_id" id="vendedor_id">
          <input type="hidden" name="nota" id="nota">

          <div class="stars" id="stars">
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
          </div>

          <textarea name="comentario" class="form-control mt-3" placeholder="Comentário"></textarea>

        </div>

        <div class="modal-footer">
          <button type="submit" class="btn btn-success">Enviar</button>
        </div>

      </form>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
const modal = new bootstrap.Modal(document.getElementById('modalAvaliacao'));

document.querySelectorAll('.abrir-avaliacao').forEach(btn => {
  btn.addEventListener('click', () => {

    document.getElementById('pedido_id').value = btn.dataset.id;
    document.getElementById('vendedor_id').value = btn.dataset.vendedor;

    document.querySelectorAll("#stars span").forEach(s => s.classList.remove("active"));
    document.getElementById("nota").value = "";

    modal.show();
  });
});

const stars = document.querySelectorAll("#stars span");
const inputNota = document.getElementById("nota");

stars.forEach((star, index) => {
  star.addEventListener("click", () => {
    inputNota.value = index + 1;

    stars.forEach(s => s.classList.remove("active"));

    for(let i = 0; i <= index; i++){
      stars[i].classList.add("active");
    }
  });
});
</script>

</body>
</html>