<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Pedidos - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/header') %>

<div class="content">

<div class="title">Meus Pedidos</div>

<% if (!pedidos || pedidos.length === 0) { %>
  <div class="alert alert-warning">Nenhum pedido encontrado</div>
<% } %>

<div class="grid">

<% (pedidos || []).forEach(p => { %>

  <div class="card-pedido">

    <div class="card-header">
      <strong>#Pedido <%= p.id %></strong>

      <span class="status 
        <%= p.status === 'PENDENTE' ? 'status-pendente' : '' %>
        <%= p.status === 'PREPARANDO' ? 'status-preparando' : '' %>
        <%= p.status === 'ENTREGUE' ? 'status-entregue' : '' %>">
        <%= p.status || '---' %>
      </span>
    </div>

    <div class="itens"><%= p.itens || 'Sem itens' %></div>
    <div class="total">R$ <%= p.valor_total || 0 %></div>

    <% if (p.status === "ENTREGUE") { %>

      <% if (p.avaliado) { %>

        <button class="btn-avaliar btn-disabled" disabled>
          Já avaliado
        </button>

      <% } else { %>

        <button 
          type="button"
          class="btn-avaliar abrir-avaliacao"
          data-id="<%= p.id %>"
          data-vendedor="<%= p.vendedor_id %>">
          Avaliar
        </button>

      <% } %>

    <% } %>

  </div>

<% }) %>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>