<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Cliente - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:#f8fafc;
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:240px;
  height:100vh;
  background:#111827;
  color:#fff;
  padding:25px;
  position:fixed;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.logo{
  font-weight:700;
  font-size:18px;
  margin-bottom:30px;
}

.nav-link{
  display:block;
  color:#9ca3af;
  margin-bottom:12px;
  text-decoration:none;
  font-size:14px;
}

.nav-link:hover{
  color:#fff;
}

/* CONTENT */
.content{
  margin-left:240px;
  padding:40px;
  width:100%;
}

/* TOP */
.top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:25px;
}

.search-box{
  padding:12px 15px;
  border-radius:12px;
  border:1px solid #e5e7eb;
  width:260px;
  background:#fff;
}

/* FILTRO */
select{
  padding:10px;
  border-radius:10px;
  border:1px solid #e5e7eb;
  margin-bottom:25px;
  background:#fff;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:25px;
}

/* CARD */
.card-produto{
  background:#fff;
  padding:18px;
  border-radius:18px;
  box-shadow:0 8px 20px rgba(0,0,0,0.06);
  transition:0.2s;
}

.card-produto:hover{
  transform:translateY(-5px);
}

/* TEXTO */
.nome{
  font-weight:600;
  font-size:16px;
}

.vendedor{
  font-size:12px;
  color:#6b7280;
}

.desc{
  font-size:13px;
  margin:10px 0;
  color:#374151;
}

.preco{
  color:#ea580c;
  font-weight:700;
  font-size:15px;
}

/* BOTÃO */
.btn-add{
  margin-top:12px;
  width:100%;
  padding:10px;
  border:none;
  border-radius:12px;
  background:#ea580c;
  color:white;
  font-weight:600;
  transition:0.2s;
}

.btn-add:hover{
  background:#c2410c;
}

/* CARRINHO FLOAT */
.floating-cart{
  position:fixed;
  bottom:25px;
  right:25px;
  width:60px;
  height:60px;
  background:#ea580c;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
  font-weight:bold;
  cursor:pointer;
  box-shadow:0 10px 20px rgba(0,0,0,0.2);
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div>
    <div class="logo">CampusMarket</div>

    <a href="#" class="nav-link">🏠 Início</a>
    <a href="#" class="nav-link">🛒 Carrinho</a>
    <a href="#" class="nav-link">📦 Pedidos</a>
  </div>

  <div>
    <p style="font-size:13px;"><%= usuario?.nome || "Usuário" %></p>
    <a href="/logout" class="nav-link">Sair</a>
  </div>
</div>

<!-- CONTEÚDO -->
<div class="content">

  <div class="top">
    <h2>Explorar lanches</h2>

    <input type="text" id="search" class="search-box" placeholder="Buscar...">
  </div>

  <select id="filtro">
    <option value="">Todos vendedores</option>
    <% (vendedores || []).forEach(v => { %>
      <option value="<%= v.nome %>"><%= v.nome %></option>
    <% }) %>
  </select>

  <div class="grid" id="lista">

  <% (produtos || []).forEach(p => { %>

    <div class="produto"
         data-nome="<%= p.nome || '' %>"
         data-vendedor="<%= p.vendedor_nome || '' %>">

      <div class="card-produto">

        <div class="nome"><%= p.nome || 'Sem nome' %></div>

        <div class="vendedor"><%= p.vendedor_nome || 'Sem vendedor' %></div>

        <div class="desc"><%= p.descricao || '' %></div>

        <div class="preco">R$ <%= Number(p.preco || 0).toFixed(2) %></div>

        <small style="color:#9ca3af;">
          ⭐ <%= p.media_avaliacao || "Sem avaliações" %>
        </small>

        <form action="/carrinho/add" method="POST">
          <input type="hidden" name="id" value="<%= p.id %>">
          <button class="btn-add">Adicionar</button>
        </form>

      </div>

    </div>

  <% }) %>

  </div>

</div>

<!-- CARRINHO -->
<div class="floating-cart" data-bs-toggle="offcanvas" data-bs-target="#carrinho">
  <span><%= carrinho ? carrinho.length : 0 %></span>
</div>

<script>
const search = document.getElementById("search");
const filtro = document.getElementById("filtro");

function filtrar(){
  const texto = search.value.toLowerCase();
  const vend = filtro.value;

  document.querySelectorAll(".produto").forEach(el => {
    const nome = el.dataset.nome.toLowerCase();
    const vendedor = el.dataset.vendedor;

    const okNome = nome.includes(texto);
    const okVend = !vend || vendedor === vend;

    el.style.display = (okNome && okVend) ? "block" : "none";
  });
}

search.addEventListener("keyup", filtrar);
filtro.addEventListener("change", filtrar);
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>