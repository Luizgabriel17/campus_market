<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Cliente - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:#f1f5f9;
  display:flex;
}

/* SIDEBAR (PADRÃO NOVO) */
.sidebar{
  width:230px;
  height:100vh;
  background:#ffffff;
  padding:25px 20px;
  position:fixed;
  border-right:1px solid #e2e8f0;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.logo{
  font-weight:800;
  font-size:1.3rem;
  color:#ff5a1f;
  margin-bottom:30px;
}

.menu a{
  display:block;
  padding:10px;
  border-radius:10px;
  color:#334155;
  text-decoration:none;
  margin-bottom:8px;
  transition:.2s;
}

.menu a:hover{
  background:#f1f5f9;
}

.menu .active{
  background:#ff5a1f;
  color:white;
}

.user{
  font-size:0.9rem;
  color:#475569;
}

.user a{
  display:block;
  margin-top:5px;
  color:#ff5a1f;
  text-decoration:none;
}

/* CONTENT */
.content{
  margin-left:230px;
  padding:40px;
  width:100%;
}

/* TOPO */
.top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:25px;
}

.top h2{
  font-weight:800;
}

/* BUSCA */
.search-box{
  padding:12px;
  border-radius:12px;
  border:1px solid #ddd;
  width:280px;
}

/* FILTRO */
select{
  padding:10px;
  border-radius:10px;
  border:1px solid #ddd;
  margin-bottom:20px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:25px;
}

/* CARD */
.card-produto{
  background:#fff;
  padding:20px;
  border-radius:18px;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
  transition:.25s;
}

.card-produto:hover{
  transform:translateY(-6px);
}

.card-produto h5{
  font-weight:700;
}

/* BOTÃO */
.btn-add{
  margin-top:10px;
  width:100%;
  padding:10px;
  border:none;
  border-radius:12px;
  background:#ff5a1f;
  color:white;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
}

.btn-add:hover{
  transform:translateY(-2px);
}

.add-btn.added{
  background:#28a745;
}

/* FLOATING CART */
.floating-cart{
  position:fixed;
  bottom:25px;
  right:25px;
  background:#ff5a1f;
  color:white;
  padding:15px 20px;
  border-radius:50px;
  font-size:1.2rem;
  font-weight:600;
  cursor:pointer;
  box-shadow:0 10px 25px rgba(0,0,0,0.2);
  z-index:999;
}

.floating-cart span{
  background:white;
  color:#ff5a1f;
  padding:3px 8px;
  border-radius:50%;
  margin-left:5px;
}

/* ANIMAÇÃO */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}
</style>
</head>

<body>

<%- include('partials/header') %>
<%- include('partials/carrinho') %>

<div class="content">

<div class="top">
  <h2>Explorar lanches</h2>
  <input type="text" id="search" class="search-box" placeholder="Buscar...">
</div>

<select id="filtro">
  <option value="">Todos vendedores</option>
  <% vendedores.forEach(v => { %>
    <option value="<%= v.nome %>"><%= v.nome %></option>
  <% }) %>
</select>

<div class="grid" id="lista">

<% produtos.forEach(p => { %>

  <div class="produto"
       data-nome="<%= p.nome %>"
       data-vendedor="<%= p.vendedor_nome %>">

    <div class="card-produto">

      <h5><%= p.nome %></h5>

      <p><%= p.vendedor_nome %></p>

      <p><%= p.descricao %></p>

      <strong>R$ <%= p.preco %></strong>

      <p><%= p.media_avaliacao || "Sem avaliações" %></p>

      <form action="/carrinho/add" method="POST">
        <input type="hidden" name="id" value="<%= p.id %>">
        <input type="hidden" name="nome" value="<%= p.nome %>">
        <input type="hidden" name="preco" value="<%= p.preco %>">
        <input type="hidden" name="vendedor_id" value="<%= p.vendedor_id %>">

        <button class="btn-add add-btn">Adicionar</button>
      </form>

    </div>

  </div>

<% }) %>

</div>

</div>

<div class="floating-cart" data-bs-toggle="offcanvas" data-bs-target="#carrinho">
  <span id="cartCount"><%= session.carrinho ? session.carrinho.length : 0 %></span>
</div>

<script>
const search = document.getElementById("search");
const filtro = document.getElementById("filtro");

search.addEventListener("keyup", filtrar);
filtro.addEventListener("change", filtrar);

function filtrar(){
  const texto = search.value.toLowerCase();
  const vend = filtro.value;

  document.querySelectorAll(".produto").forEach(el => {
    const nome = el.dataset.nome.toLowerCase();
    const vendedor = el.dataset.vendedor;

    const okNome = nome.includes(texto);
    const okVend = !vend || vendedor === vend;

    el.style.display = (okNome && okVend) ? "block" : "none";
  });
}
</script>

<script>
document.querySelectorAll(".add-btn").forEach(btn => {
  btn.addEventListener("click", function(){

    const original = btn.innerHTML;

    btn.innerHTML = "✔ Adicionado";
    btn.classList.add("added");

    setTimeout(()=>{
      btn.innerHTML = original;
      btn.classList.remove("added");
    },1000);

  });
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<%- include('partials/footer') %>

</body>
</html>