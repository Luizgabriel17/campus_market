<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Cliente - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:#f1f5f9;
  display:flex;
}

.sidebar{
  width:230px;
  height:100vh;
  background:#ffffff;
  padding:25px 20px;
  position:fixed;
  border-right:1px solid #e2e8f0;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}

.content{
  margin-left:230px;
  padding:40px;
  width:100%;
}

.top{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:25px;
}

.search-box{
  padding:12px;
  border-radius:12px;
  border:1px solid #ddd;
  width:280px;
}

select{
  padding:10px;
  border-radius:10px;
  border:1px solid #ddd;
  margin-bottom:20px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:25px;
}

.card-produto{
  background:#fff;
  padding:20px;
  border-radius:18px;
  box-shadow:0 10px 25px rgba(0,0,0,0.08);
}

.btn-add{
  margin-top:10px;
  width:100%;
  padding:10px;
  border:none;
  border-radius:12px;
  background:#ff5a1f;
  color:white;
  font-weight:600;
}
</style>
</head>

<body>

<%- include('partials/header') %>
<%- include('partials/carrinho') %>

<div class="content">

<div class="top">
  <h2>Explorar lanches</h2>
  <input type="text" id="search" class="search-box" placeholder="Buscar...">
</div>

<select id="filtro">
  <option value="">Todos vendedores</option>
  <% (vendedores || []).forEach(v => { %>
    <option value="<%= v.nome %>"><%= v.nome %></option>
  <% }) %>
</select>

<div class="grid" id="lista">

<% (produtos || []).forEach(p => { %>

  <div class="produto"
       data-nome="<%= p.nome || '' %>"
       data-vendedor="<%= p.vendedor_nome || '' %>">

    <div class="card-produto">

      <h5><%= p.nome || 'Sem nome' %></h5>

      <p><%= p.vendedor_nome || 'Sem vendedor' %></p>

      <p><%= p.descricao || '' %></p>

      <strong>R$ <%= Number(p.preco || 0).toFixed(2) %></strong>

      <p><%= p.media_avaliacao || "Sem avaliações" %></p>

      <form action="/carrinho/add" method="POST">
        <input type="hidden" name="id" value="<%= p.id %>">
        <button class="btn-add">Adicionar</button>
      </form>

    </div>

  </div>

<% }) %>

</div>

</div>

<!-- CORRIGIDO -->
<div class="floating-cart" data-bs-toggle="offcanvas" data-bs-target="#carrinho">
  <span id="cartCount"><%= carrinho ? carrinho.length : 0 %></span>
</div>

<script>
const search = document.getElementById("search");
const filtro = document.getElementById("filtro");

function filtrar(){
  const texto = search.value.toLowerCase();
  const vend = filtro.value;

  document.querySelectorAll(".produto").forEach(el => {
    const nome = el.dataset.nome.toLowerCase();
    const vendedor = el.dataset.vendedor;

    const okNome = nome.includes(texto);
    const okVend = !vend || vendedor === vend;

    el.style.display = (okNome && okVend) ? "block" : "none";
  });
}

search.addEventListener("keyup", filtrar);
filtro.addEventListener("change", filtrar);
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>