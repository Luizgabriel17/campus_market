<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Pedidos - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<%- include('partials/header') %>

<div class="dashboard">

  <div class="top">
    <h2>Pedidos Recebidos</h2>
  </div>

  <% if (!pedidos || pedidos.length === 0) { %>
    <div class="alert alert-warning">
      Nenhum pedido recebido ainda.
    </div>
  <% } %>

  <div class="grid">

    <% (pedidos || []).forEach(p => { %>

      <div class="pedido-card">

        <strong>#Pedido <%= p.id %></strong>

        <p class="mt-2"><%= p.itens || 'Sem itens' %></p>

        <p><strong>R$ <%= p.valor_total || 0 %></strong></p>

        <span class="status 
          <%= p.status === 'PENDENTE' ? 'status-pendente' : '' %>
          <%= p.status === 'PREPARANDO' ? 'status-preparando' : '' %>
          <%= p.status === 'SAIU' ? 'status-saiu' : '' %>
          <%= p.status === 'ENTREGUE' ? 'status-entregue' : '' %>">
          <%= p.status || '---' %>
        </span>

        <form action="/dashboard/pedidos/status/<%= p.id %>" method="POST" class="mt-3">

          <select name="status" class="form-control mb-2">
            <option>PENDENTE</option>
            <option>PREPARANDO</option>
            <option>SAIU</option>
            <option>ENTREGUE</option>
          </select>

          <button class="btn btn-primary btn-sm w-100">
            Atualizar Status
          </button>

        </form>

      </div>

    <% }) %>

  </div>

</div>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>