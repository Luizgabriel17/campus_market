<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Produtos - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<%- include('partials/header') %>

<div class="dashboard">

  <div class="top">
    <h2>Meus Produtos</h2>
    <a href="/dashboard/produtos/novo" class="btn btn-success">+ Novo Produto</a>
  </div>

  <% if (produtos.length === 0) { %>
    <div class="alert alert-warning">
      Nenhum produto cadastrado ainda.
    </div>
  <% } %>

  <div class="grid">

    <% produtos.forEach(p => { %>

      <div class="produto-card">

        <h5><%= p.nome %></h5>

        <p><%= p.descricao %></p>

        <strong>R$ <%= p.preco %></strong>

        <p class="mt-2">Estoque: <%= p.estoque %></p>

        <div class="btn-group">

          <a href="/dashboard/produtos/editar/<%= p.id %>" class="btn btn-warning btn-sm">
            Editar
          </a>

          <form action="/dashboard/produtos/deletar/<%= p.id %>" method="POST">
            <button class="btn btn-danger btn-sm">
              Excluir
            </button>
          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>