<div class="offcanvas offcanvas-end" id="carrinho"></div>

  <div class="offcanvas-header">
    <h5>Seu Carrinho</h5>
    <button class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">

    <% let total = 0; %>

    <% if (carrinho && carrinho.length > 0) { %>

      <% carrinho.forEach(item => { 
        total += item.preco * item.quantidade;
      %>

        <div class="cart-item">

          <div class="cart-info">
            <strong><%= item.nome %></strong>
            <span>R$ <%= Number(item.preco).toFixed(2) %></span>
          </div>

          <div class="cart-actions">

            <form action="/carrinho/update" method="POST">
              <input type="hidden" name="id" value="<%= item.id %>">
              <input type="hidden" name="acao" value="menos">
              <button class="btn-qty">-</button>
            </form>

            <span class="qty"><%= item.quantidade %></span>

            <form action="/carrinho/update" method="POST">
              <input type="hidden" name="id" value="<%= item.id %>">
              <input type="hidden" name="acao" value="mais">
              <button class="btn-qty">+</button>
            </form>

            <form action="/carrinho/remove" method="POST">
              <input type="hidden" name="id" value="<%= item.id %>">
              <button class="remove-btn">Remover</button>
            </form>

          </div>

        </div>

      <% }) %>

      <div class="cart-footer">

        <div class="total">
          Total: R$ <%= total.toFixed(2) %>
        </div>

        <form action="/pedidos/finalizar" method="POST">
          <button class="btn-finalizar">
            Finalizar Pedido
          </button>
        </form>

      </div>

    <% } else { %>

      <div class="empty-cart">
        Carrinho vazio
      </div>

    <% } %>

  </div>

</div>