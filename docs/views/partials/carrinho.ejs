<div class="offcanvas offcanvas-end" id="carrinho">

  <div class="offcanvas-header">
    <h5>Seu Carrinho</h5>
    <button class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">

    <% let total = 0; %>

    <% if (carrinho && carrinho.length > 0) { %>

      <% carrinho.forEach(item => { 
        total += item.preco * item.quantidade;
      %>

        <div class="mb-3 border-bottom pb-2">

          <strong><%= item.nome %></strong>

          <p>R$ <%= Number(item.preco).toFixed(2) %></p>

          <div class="d-flex align-items-center">

            <form action="/carrinho/update" method="POST">
              <input type="hidden" name="id" value="<%= item.id %>">
              <input type="hidden" name="acao" value="menos">
              <button class="btn btn-sm btn-danger">-</button>
            </form>

            <span class="mx-2"><%= item.quantidade %></span>

            <form action="/carrinho/update" method="POST">
              <input type="hidden" name="id" value="<%= item.id %>">
              <input type="hidden" name="acao" value="mais">
              <button class="btn btn-sm btn-success">+</button>
            </form>

            <form action="/carrinho/remove" method="POST" class="ms-3">
              <input type="hidden" name="id" value="<%= item.id %>">
              <button class="btn btn-sm btn-outline-danger">Remover</button>
            </form>

          </div>

        </div>

      <% }) %>

      <h5 class="mt-3">Total: R$ <%= total.toFixed(2) %></h5>

      <form action="/pedidos/finalizar" method="POST">
        <button class="btn btn-success w-100 mt-2">
          Finalizar Pedido
        </button>
      </form>

    <% } else { %>

      <p>Carrinho vazio</p>

    <% } %>

  </div>

</div>