<% if (typeof user !== 'undefined' && user) { %>

<!-- MOBILE TOP -->
<div class="mobile-top">
  <button class="menu-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
    ☰
  </button>
  <span class="mobile-title">CampusMarket</span>
</div>

<!-- SIDEBAR -->
<div class="sidebar desktop">

  <a href="/" class="logo">CampusMarket</a>

  <nav class="menu">

    <% if (user.tipo === "cliente") { %>

      <a href="/cliente" class="<%= url === '/cliente' ? 'active' : '' %>">Início</a>

      <a href="#" data-bs-toggle="offcanvas" data-bs-target="#carrinho">
        Carrinho
      </a>

      <a href="/pedidos" class="<%= url === '/pedidos' ? 'active' : '' %>">Pedidos</a>

    <% } %>

    <% if (user.tipo === "vendedor") { %>

      <a href="/dashboard" class="<%= url === '/dashboard' ? 'active' : '' %>">Dashboard</a>

      <a href="/dashboard/produtos"
         class="<%= url && url.includes('/dashboard/produtos') ? 'active' : '' %>">
         Produtos
      </a>

      <a href="/dashboard/pedidos"
         class="<%= url && url.includes('/dashboard/pedidos') ? 'active' : '' %>">
         Pedidos
      </a>

    <% } %>

  </nav>

  <div class="user">
    <p><%= user.nome %></p>
    <a href="/logout">Sair</a>
  </div>

</div>

<!-- MOBILE MENU -->
<div class="offcanvas offcanvas-start" id="mobileMenu">

  <div class="offcanvas-header">
    <h5>Menu</h5>
    <button class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">

    <% if (user.tipo === "cliente") { %>
      <a href="/cliente" class="menu-item">Início</a>
      <a href="#" data-bs-toggle="offcanvas" data-bs-target="#carrinho" class="menu-item">Carrinho</a>
      <a href="/pedidos" class="menu-item">Pedidos</a>
    <% } %>

    <% if (user.tipo === "vendedor") { %>
      <a href="/dashboard" class="menu-item">Dashboard</a>
      <a href="/dashboard/produtos" class="menu-item">Produtos</a>
      <a href="/dashboard/pedidos" class="menu-item">Pedidos</a>
    <% } %>

    <hr>

    <p><%= user.nome %></p>
    <a href="/logout">Sair</a>

  </div>

</div>

<% } %>