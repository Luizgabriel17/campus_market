<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Editar Produto - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/header') %>

<div class="content">

  <div class="form-card">

    <h3>Editar Produto</h3>

    <% if (!produto) { %>
      <div class="alert alert-danger">Produto não encontrado</div>
    <% } else { %>

    <form action="/dashboard/produtos/editar/<%= produto.id %>" method="POST">

      <input class="form-control mb-3" name="nome" value="<%= produto.nome || '' %>" required>

      <textarea class="form-control mb-3" name="descricao"><%= produto.descricao || '' %></textarea>

      <input class="form-control mb-3" type="number" step="0.01" name="preco" value="<%= produto.preco || 0 %>" required>

      <input class="form-control mb-3" type="number" name="estoque" value="<%= produto.estoque || 0 %>" required>

      <button class="btn-main">Salvar Alterações</button>

    </form>

    <% } %>

  </div>

</div>

</body>
</html>